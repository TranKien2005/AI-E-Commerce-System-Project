{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:storefront",
    "dev:storefront": "next dev storefront -p 3000",
    "dev:admin": "next dev admin -p 3001",
    "build": "npm run build:storefront && npm run build:admin",
    "build:storefront": "next build storefront",
    "build:admin": "next build admin",
    "start:storefront": "next start storefront -p 3000",
    "start:admin": "next start admin -p 3001",
    "lint": "npm run lint:storefront && npm run lint:admin",
    "lint:storefront": "cd storefront && eslint src",
    "lint:admin": "cd admin && eslint src",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
