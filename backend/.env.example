APP_NAME=AI E-Commerce Backend
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5433/ecommerce

SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=20160

AI_SEARCH_MODE=mock
AI_SEARCH_BASE_URL=
AI_SEARCH_API_KEY=
AI_SEARCH_TIMEOUT_SECONDS=5

RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_AUTH=10/minute
CIRCUIT_BREAKER_FAIL_MAX=5
CIRCUIT_BREAKER_RESET_TIMEOUT_SECONDS=30

TRACING_ENABLED=true
OTEL_SERVICE_NAME=ecommerce-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

EMAIL_BACKEND=smtp

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@ecommerce.local

RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
